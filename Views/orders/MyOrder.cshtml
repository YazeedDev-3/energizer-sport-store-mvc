@model IEnumerable<project_web2.Models.Orders>
@{
    ViewData["Title"] = "My Orders";
    Layout = "~/Views/Shared/layoutCustomer.cshtml";
    ViewData["BodyClass"] = "my-orders-page";
    var orderList = Model.ToList();
}

<div class="container-xl px-4 py-5">

    <h2 class="orders-heading">Order History</h2>
    <div class="section-underline"></div>

    @if (!orderList.Any())
    {
        <div class="orders-empty">
            <div class="orders-empty-icon"><i class="bi bi-receipt"></i></div>
            <h3>No orders yet</h3>
            <p>You haven't placed any orders. Start shopping to see your history here.</p>
            <a asp-action="CatalogueBuy" asp-controller="orders" class="btn-shop-now">
                <i class="bi bi-bag me-2"></i>Shop Now
            </a>
        </div>
    }
    else
    {
        <div class="orders-table-wrapper">
            <table class="orders-table">
                <thead>
                    <tr>
                        <th>Order #</th>
                        <th>Date</th>
                        <th>Total</th>
                        <th>Details</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in orderList)
                    {
                        <tr>
                            <td><span class="order-id-chip">#@item.Id</span></td>
                            <td>@item.OrderDate.ToString("dd MMM yyyy")</td>
                            <td class="order-total-val">@item.Total SR</td>
                            <td>
                                <a asp-action="Orderline" asp-route-orid="@item.Id" class="btn-view-order">
                                    <i class="bi bi-eye me-1"></i>View
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

</div>
