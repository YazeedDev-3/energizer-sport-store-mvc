@model IEnumerable<project_web2.Models.OrderItemView>

@{
    ViewData["Title"] = "Order Items";
    var isAdmin = (string)ViewBag.role == "admin";
}

@if (!isAdmin)
{
    Layout = "~/Views/Shared/layoutCustomer.cshtml";
}

@* ── Customer view ── *@
@if (!isAdmin)
{
    <style>
        .orderline-table tbody tr:nth-child(even) { background-color: rgba(255,255,255,0.03); }
        .orderline-table tbody tr:hover { background-color: rgba(255,107,0,0.05); }
    </style>

    <div class="container-xl" style="padding-top:2.5rem;padding-bottom:4rem;">
        <div class="section-heading">Order Items</div>
        <div class="section-underline"></div>

        <div class="orders-table-wrapper">
            <table class="orderline-table" style="width:100%;border-collapse:collapse;font-size:.88rem;">
                <thead>
                    <tr>
                        <th style="background:#ff6b00;color:#fff;font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.6px;padding:.85rem 1.1rem;border-bottom:2px solid #e05f00;">Product</th>
                        <th style="background:#ff6b00;color:#fff;font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.6px;padding:.85rem 1.1rem;border-bottom:2px solid #e05f00;text-align:center;">Qty</th>
                        <th style="background:#ff6b00;color:#fff;font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.6px;padding:.85rem 1.1rem;border-bottom:2px solid #e05f00;text-align:right;">Unit Price</th>
                        <th style="background:#ff6b00;color:#fff;font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.6px;padding:.85rem 1.1rem;border-bottom:2px solid #e05f00;text-align:right;">Line Total</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td style="padding:1rem 1.1rem;color:#f1f1f1;border-bottom:1px solid #2d2d4e;font-weight:600;">@item.ItemName</td>
                            <td style="padding:1rem 1.1rem;color:#d1d5db;border-bottom:1px solid #2d2d4e;text-align:center;">@item.Quantity</td>
                            <td style="padding:1rem 1.1rem;color:#d1d5db;border-bottom:1px solid #2d2d4e;text-align:right;">@item.UnitPrice.ToString("N2") SR</td>
                            <td style="padding:1rem 1.1rem;color:#f1f1f1;border-bottom:1px solid #2d2d4e;text-align:right;font-weight:700;">@((item.Quantity * item.UnitPrice).ToString("N2")) SR</td>
                        </tr>
                    }
                </tbody>
                @if (Model.Any())
                {
                    <tfoot>
                        <tr>
                            <td colspan="3" style="padding:.9rem 1.1rem;background:#111827;color:#9ca3af;font-size:.78rem;font-weight:700;text-transform:uppercase;letter-spacing:.5px;border-top:2px solid #374151;">Order Total</td>
                            <td style="padding:.9rem 1.1rem;background:#111827;color:#ff6b00;font-size:1.05rem;font-weight:800;text-align:right;border-top:2px solid #374151;">
                                @Model.Sum(i => i.Quantity * i.UnitPrice).ToString("N2") SR
                            </td>
                        </tr>
                    </tfoot>
                }
            </table>

            @if (!Model.Any())
            {
                <div style="text-align:center;padding:3rem 2rem;color:#6b7280;">
                    <i class="bi bi-cart-x" style="font-size:2.5rem;display:block;margin-bottom:.75rem;color:#374151;"></i>
                    No items found for this order.
                </div>
            }
        </div>

        <div style="margin-top:1.5rem;">
            <a asp-action="MyOrder" class="btn-view-order">
                <i class="bi bi-arrow-left"></i> Back to My Orders
            </a>
        </div>
    </div>
    return;
}

@* ── Admin view ── *@
<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;">
    <div>
        <div class="admin-page-title">Order Items</div>
        <div class="admin-page-sub">Line items for this order</div>
    </div>
    <a asp-action="Index" class="btn-admin-sm btn-view">
        <i class="bi bi-arrow-left"></i> Back to Report
    </a>
</div>

<div class="admin-card" style="padding:0;overflow:hidden;">
    <table class="admin-table">
        <thead>
            <tr>
                <th>#</th>
                <th>Product</th>
                <th style="text-align:center;">Qty</th>
                <th style="text-align:right;">Unit Price</th>
                <th style="text-align:right;">Line Total</th>
            </tr>
        </thead>
        <tbody>
            @{ int row = 0; }
            @foreach (var item in Model)
            {
                row++;
                <tr>
                    <td style="color:#bbb;font-size:.8rem;">@row</td>
                    <td style="font-weight:600;color:#1a1a2e;">@item.ItemName</td>
                    <td style="text-align:center;">@item.Quantity</td>
                    <td style="text-align:right;">@item.UnitPrice.ToString("N2") SR</td>
                    <td style="text-align:right;font-weight:700;color:#1b9950;">
                        @((item.Quantity * item.UnitPrice).ToString("N2")) SR
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (!Model.Any())
    {
        <div style="text-align:center;padding:40px;color:#aaa;">
            <i class="bi bi-cart-x" style="font-size:2rem;display:block;margin-bottom:10px;"></i>
            No items found for this order.
        </div>
    }
</div>

@if (Model.Any())
{
    <div class="admin-card" style="margin-top:0;">
        <div style="display:flex;align-items:center;justify-content:space-between;">
            <span style="font-size:.875rem;color:#888;font-weight:600;">Order Total — @Model.Count() item(s)</span>
            <span style="font-size:1.15rem;font-weight:800;color:#1a1a2e;">
                @Model.Sum(i => i.Quantity * i.UnitPrice).ToString("N2") SR
            </span>
        </div>
    </div>
}
