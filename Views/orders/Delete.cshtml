@model project_web2.Models.Orders

@{
    ViewData["Title"] = "Delete Order";
}

<div style="max-width:480px;">
    <div class="admin-page-title" style="margin-bottom:4px;">Delete Order</div>
    <div class="admin-page-sub">This action cannot be undone.</div>

    <div class="admin-card" style="border-top:4px solid #c62828;">
        <div style="background:#f8f9fc;border-radius:8px;padding:16px 20px;margin-bottom:20px;">
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;font-size:.875rem;">
                <div>
                    <div style="color:#888;font-size:.75rem;font-weight:600;text-transform:uppercase;letter-spacing:.05em;">Order #</div>
                    <div style="font-weight:700;color:#1a1a2e;margin-top:2px;">#@Model.Id</div>
                </div>
                <div>
                    <div style="color:#888;font-size:.75rem;font-weight:600;text-transform:uppercase;letter-spacing:.05em;">User ID</div>
                    <div style="font-weight:700;color:#1a1a2e;margin-top:2px;">@Model.UserId</div>
                </div>
                <div>
                    <div style="color:#888;font-size:.75rem;font-weight:600;text-transform:uppercase;letter-spacing:.05em;">Date</div>
                    <div style="font-weight:700;color:#1a1a2e;margin-top:2px;">@Model.OrderDate.ToString("dd MMM yyyy")</div>
                </div>
                <div>
                    <div style="color:#888;font-size:.75rem;font-weight:600;text-transform:uppercase;letter-spacing:.05em;">Total</div>
                    <div style="font-weight:700;color:#1b9950;margin-top:2px;">@Model.Total.ToString("N2") SR</div>
                </div>
            </div>
        </div>

        <div style="background:#fdecea;border-radius:8px;padding:12px 16px;display:flex;align-items:center;gap:10px;margin-bottom:24px;font-size:.875rem;color:#c62828;">
            <i class="bi bi-exclamation-triangle-fill"></i>
            Are you sure you want to permanently delete order <strong>#@Model.Id</strong>?
        </div>

        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />
            <div style="display:flex;gap:12px;">
                <button type="submit" class="btn-admin-primary" style="background:#c62828;">
                    <i class="bi bi-trash"></i> Yes, Delete
                </button>
                <a asp-action="Index" class="btn-admin-sm btn-view" style="padding:9px 18px;">
                    Cancel
                </a>
            </div>
        </form>
    </div>
</div>
