@model project_web2.Models.Orders

@{
    ViewData["Title"] = "Order Details";
}

<div style="max-width:480px;">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;">
        <div>
            <div class="admin-page-title">Order Details</div>
            <div class="admin-page-sub">Order #@Model.Id</div>
        </div>
        <a asp-action="Index" class="btn-admin-sm btn-view">
            <i class="bi bi-arrow-left"></i> Back to Report
        </a>
    </div>

    <div class="admin-card">
        <div style="display:flex;flex-direction:column;gap:14px;font-size:.875rem;margin-bottom:24px;">
            <div style="display:flex;justify-content:space-between;padding-bottom:12px;border-bottom:1px solid #f0f2f5;">
                <span style="color:#888;font-weight:600;">Order ID</span>
                <span style="font-weight:700;color:#1a1a2e;">#@Model.Id</span>
            </div>
            <div style="display:flex;justify-content:space-between;padding-bottom:12px;border-bottom:1px solid #f0f2f5;">
                <span style="color:#888;font-weight:600;">User ID</span>
                <span style="font-weight:700;color:#1a1a2e;">@Model.UserId</span>
            </div>
            <div style="display:flex;justify-content:space-between;padding-bottom:12px;border-bottom:1px solid #f0f2f5;">
                <span style="color:#888;font-weight:600;">Order Date</span>
                <span style="font-weight:700;color:#1a1a2e;">@Model.OrderDate.ToString("dd MMM yyyy")</span>
            </div>
            <div style="display:flex;justify-content:space-between;">
                <span style="color:#888;font-weight:600;">Total</span>
                <span style="font-weight:800;color:#1b9950;font-size:1rem;">@Model.Total.ToString("N2") SR</span>
            </div>
        </div>

        <div style="display:flex;gap:10px;">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-admin-sm btn-edit" style="padding:8px 18px;">
                <i class="bi bi-pencil"></i> Edit
            </a>
            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn-admin-sm btn-delete" style="padding:8px 18px;">
                <i class="bi bi-trash"></i> Delete
            </a>
        </div>
    </div>
</div>
