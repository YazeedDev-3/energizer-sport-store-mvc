<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Energizer Sport</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/project_web2.styles.css" asp-append-version="true" />
</head>
@{
    var isLoggedIn = Context.Session.GetString("Role") != null;
    var cartJson = Context.Session.GetString("Cart");
    var cartCount = 0;
    if (isLoggedIn && !string.IsNullOrEmpty(cartJson))
    {
        using var doc = System.Text.Json.JsonDocument.Parse(cartJson);
        cartCount = doc.RootElement.GetArrayLength();
    }
}
<body class="customer-layout @(ViewData["BodyClass"] as string ?? "")">

    <header>
        <nav class="store-navbar navbar navbar-expand-md">
            <div class="container-xl">

                <a class="store-brand" asp-controller="orders" asp-action="CatalogueBuy">
                    <img src="~/images/Energizer_Sport_Logo.png" alt="Energizer Sport" class="navbar-logo" />
                    <span class="brand-name">Energizer Sport</span>
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav"
                        aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                    <i class="bi bi-list" style="font-size:1.6rem; color:#f1f1f1;"></i>
                </button>

                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav mx-auto mb-2 mb-md-0">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="orders" asp-action="CatalogueBuy">Catalogue</a>
                        </li>
                        @if (isLoggedIn)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="useraccounts" asp-action="customerHome">Special Offers</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="orders" asp-action="MyOrder">My Purchase</a>
                            </li>
                        }
                    </ul>

                    <div class="nav-actions">
                        @if (isLoggedIn)
                        {
                            <a class="cart-link" asp-controller="orders" asp-action="CartBuy" title="My Cart">
                                <i class="bi bi-cart3"></i>
                                @if (cartCount > 0)
                                {
                                    <span class="cart-badge">@cartCount</span>
                                }
                            </a>
                            <a class="btn-nav-outline" asp-controller="useraccounts" asp-action="logout">Logout</a>
                        }
                        else
                        {
                            <a class="btn-nav-outline" asp-controller="useraccounts" asp-action="Login">Login</a>
                            <a class="btn-nav-primary" asp-controller="useraccounts" asp-action="registration">Register</a>
                        }
                    </div>
                </div>

            </div>
        </nav>
    </header>

    <div class="site-content">
        @RenderBody()
    </div>

    <footer class="store-footer">
        <div class="container-xl">
            <div class="footer-brand">Energizer Sport</div>
            <div class="footer-tagline">Fuel Your Performance. Train Harder. Recover Faster.</div>
            <div class="footer-copy">&copy; @DateTime.Now.Year Energizer Sport. All rights reserved.</div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
