<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Energizer Sport Admin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        :root {
            --sidebar-bg: #1a1a2e;
            --sidebar-hover: #16213e;
            --sidebar-active: #ff6b00;
            --accent: #ff6b00;
            --topbar-bg: #ffffff;
            --content-bg: #f4f6fb;
            --sidebar-width: 240px;
            --topbar-height: 60px;
        }

        * { box-sizing: border-box; }

        body {
            margin: 0;
            font-family: 'Segoe UI', sans-serif;
            background: var(--content-bg);
            min-height: 100vh;
        }

        /* ── Sidebar ── */
        .admin-sidebar {
            position: fixed;
            top: 0; left: 0;
            width: var(--sidebar-width);
            height: 100vh;
            background: var(--sidebar-bg);
            display: flex;
            flex-direction: column;
            z-index: 1000;
            transition: transform .3s ease;
            overflow-y: auto;
        }

        .sidebar-brand {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 20px 20px 16px;
            border-bottom: 1px solid rgba(255,255,255,.08);
        }

        .sidebar-brand img { width: 36px; height: 36px; object-fit: contain; }

        .sidebar-brand-name {
            color: #ffffff;
            font-weight: 700;
            font-size: .95rem;
            line-height: 1.2;
        }

        .sidebar-brand-sub {
            color: var(--accent);
            font-size: .7rem;
            font-weight: 600;
            letter-spacing: .05em;
            text-transform: uppercase;
        }

        .sidebar-nav { flex: 1; padding: 12px 0; }

        .sidebar-section-label {
            color: rgba(255,255,255,.35);
            font-size: .65rem;
            font-weight: 700;
            letter-spacing: .12em;
            text-transform: uppercase;
            padding: 14px 20px 6px;
        }

        .sidebar-link {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 11px 20px;
            color: rgba(255,255,255,.72);
            text-decoration: none;
            font-size: .875rem;
            font-weight: 500;
            border-left: 3px solid transparent;
            transition: all .18s;
        }

        .sidebar-link i { font-size: 1rem; width: 18px; text-align: center; }

        .sidebar-link:hover {
            background: var(--sidebar-hover);
            color: #ffffff;
            border-left-color: var(--accent);
        }

        .sidebar-link.active {
            background: rgba(255,107,0,.12);
            color: var(--accent);
            border-left-color: var(--accent);
        }

        .sidebar-logout {
            padding: 16px 20px;
            border-top: 1px solid rgba(255,255,255,.08);
        }

        .sidebar-logout a {
            display: flex;
            align-items: center;
            gap: 10px;
            color: rgba(255,255,255,.55);
            text-decoration: none;
            font-size: .875rem;
            padding: 10px 14px;
            border-radius: 8px;
            transition: all .18s;
        }

        .sidebar-logout a:hover { background: rgba(220,53,69,.15); color: #ff6b6b; }

        /* ── Top bar ── */
        .admin-topbar {
            position: fixed;
            top: 0;
            left: var(--sidebar-width);
            right: 0;
            height: var(--topbar-height);
            background: var(--topbar-bg);
            border-bottom: 1px solid #e2e8f0;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 24px;
            z-index: 900;
            box-shadow: 0 1px 4px rgba(0,0,0,.06);
        }

        .topbar-hamburger {
            display: none;
            background: none;
            border: none;
            font-size: 1.4rem;
            color: #444;
            cursor: pointer;
            padding: 4px 8px;
            border-radius: 6px;
        }

        .topbar-hamburger:hover { background: #f0f0f0; }

        .topbar-title {
            font-weight: 600;
            color: #1a1a2e;
            font-size: 1rem;
        }

        .topbar-right {
            display: flex;
            align-items: center;
            gap: 14px;
        }

        .topbar-welcome {
            font-size: .875rem;
            color: #555;
        }

        .topbar-welcome strong { color: #1a1a2e; }

        .topbar-avatar {
            width: 36px; height: 36px;
            background: var(--accent);
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            color: #fff;
            font-weight: 700;
            font-size: .85rem;
        }

        /* ── Content ── */
        .admin-content {
            margin-left: var(--sidebar-width);
            margin-top: var(--topbar-height);
            padding: 28px 28px 40px;
            min-height: calc(100vh - var(--topbar-height));
        }

        /* ── Overlay (mobile) ── */
        .sidebar-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,.45);
            z-index: 999;
        }

        /* ── Responsive ── */
        @@media (max-width: 768px) {
            .admin-sidebar { transform: translateX(-100%); }
            .admin-sidebar.open { transform: translateX(0); }
            .admin-topbar { left: 0; }
            .admin-content { margin-left: 0; }
            .topbar-hamburger { display: flex; }
            .sidebar-overlay.open { display: block; }
        }

        /* ── Shared admin card ── */
        .admin-card {
            background: #fff;
            border-radius: 12px;
            box-shadow: 0 2px 12px rgba(0,0,0,.06);
            padding: 24px;
            margin-bottom: 24px;
        }

        .admin-page-title {
            font-size: 1.35rem;
            font-weight: 700;
            color: #1a1a2e;
            margin-bottom: 4px;
        }

        .admin-page-sub {
            font-size: .85rem;
            color: #888;
            margin-bottom: 24px;
        }

        /* ── Shared table ── */
        .admin-table { width: 100%; border-collapse: collapse; }
        .admin-table th {
            background: #f8f9fc;
            color: #555;
            font-size: .75rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .05em;
            padding: 11px 14px;
            border-bottom: 2px solid #e9ecef;
            white-space: nowrap;
        }
        .admin-table td {
            padding: 12px 14px;
            border-bottom: 1px solid #f0f2f5;
            font-size: .875rem;
            color: #333;
            vertical-align: middle;
        }
        .admin-table tr:hover td { background: #fafbff; }
        .admin-table tr:last-child td { border-bottom: none; }

        /* ── Buttons ── */
        .btn-admin-primary {
            background: var(--accent);
            color: #fff;
            border: none;
            border-radius: 8px;
            padding: 9px 20px;
            font-size: .875rem;
            font-weight: 600;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 7px;
            transition: background .15s;
            text-decoration: none;
        }
        .btn-admin-primary:hover { background: #e05e00; color: #fff; }

        .btn-admin-sm {
            padding: 5px 12px;
            font-size: .8rem;
            border-radius: 6px;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 5px;
            font-weight: 500;
            transition: all .15s;
        }
        .btn-edit  { background: #fff3e0; color: #e65100; border: 1px solid #ffcc80; }
        .btn-edit:hover  { background: #ffe0b2; }
        .btn-delete { background: #fdecea; color: #c62828; border: 1px solid #ef9a9a; }
        .btn-delete:hover { background: #ffcdd2; }
        .btn-view  { background: #e3f2fd; color: #1565c0; border: 1px solid #90caf9; }
        .btn-view:hover  { background: #bbdefb; }

        /* ── Stat cards (dashboard) ── */
        .stat-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px,1fr)); gap: 20px; margin-bottom: 28px; }
        .stat-card {
            background: #fff;
            border-radius: 12px;
            padding: 20px 22px;
            box-shadow: 0 2px 10px rgba(0,0,0,.06);
            display: flex;
            align-items: center;
            gap: 16px;
        }
        .stat-icon {
            width: 52px; height: 52px;
            border-radius: 12px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.4rem;
            flex-shrink: 0;
        }
        .stat-icon.orange { background: rgba(255,107,0,.12); color: var(--accent); }
        .stat-icon.blue   { background: rgba(21,101,192,.1);  color: #1565c0; }
        .stat-icon.green  { background: rgba(27,153,80,.1);   color: #1b9950; }
        .stat-icon.purple { background: rgba(103,58,183,.1);  color: #673ab7; }
        .stat-value { font-size: 1.6rem; font-weight: 800; color: #1a1a2e; line-height: 1; }
        .stat-label { font-size: .78rem; color: #888; margin-top: 3px; }

        /* ── Form fields ── */
        .admin-form-group { margin-bottom: 18px; }
        .admin-form-group label { display: block; font-size: .83rem; font-weight: 600; color: #444; margin-bottom: 6px; }
        .admin-form-group .form-control {
            border: 1px solid #dde1eb;
            border-radius: 8px;
            padding: 9px 13px;
            font-size: .875rem;
            width: 100%;
            transition: border .15s;
            background: #fff;
        }
        .admin-form-group .form-control:focus { border-color: var(--accent); outline: none; box-shadow: 0 0 0 3px rgba(255,107,0,.1); }

        /* ── Badge ── */
        .role-badge {
            display: inline-block;
            padding: 3px 10px;
            border-radius: 20px;
            font-size: .72rem;
            font-weight: 700;
            letter-spacing: .04em;
        }
        .role-admin    { background: rgba(255,107,0,.12); color: #e05e00; }
        .role-customer { background: rgba(21,101,192,.1);  color: #1565c0; }
    </style>
</head>
<body>

    <!-- Sidebar overlay (mobile) -->
    <div class="sidebar-overlay" id="sidebarOverlay" onclick="closeSidebar()"></div>

    <!-- Sidebar -->
    <aside class="admin-sidebar" id="adminSidebar">
        <div class="sidebar-brand">
            <img src="~/images/Energizer_Sport_Logo.png" alt="Logo" onerror="this.style.display='none'" />
            <div>
                <div class="sidebar-brand-name">Energizer Sport</div>
                <div class="sidebar-brand-sub">Admin Panel</div>
            </div>
        </div>

        <nav class="sidebar-nav">
            <div class="sidebar-section-label">Main</div>
            <a class="sidebar-link @(ViewContext.RouteData.Values["action"]?.ToString() == "adminhome" ? "active" : "")"
               asp-controller="useraccounts" asp-action="adminhome">
                <i class="bi bi-speedometer2"></i> Dashboard
            </a>

            <div class="sidebar-section-label">Catalogue</div>
            <a class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "items" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")"
               asp-controller="items" asp-action="Index">
                <i class="bi bi-box-seam"></i> Products
            </a>
            <a class="sidebar-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Category" ? "active" : "")"
               asp-controller="items" asp-action="Category">
                <i class="bi bi-list-ul"></i> Product List
            </a>
            <div class="sidebar-section-label">Users</div>
            <a class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "useraccounts" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")"
               asp-controller="useraccounts" asp-action="Index">
                <i class="bi bi-people"></i> All Users
            </a>
            <a class="sidebar-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Users_search" ? "active" : "")"
               asp-controller="useraccounts" asp-action="Users_search">
                <i class="bi bi-search"></i> Search Users
            </a>
            <a class="sidebar-link @(ViewContext.RouteData.Values["action"]?.ToString() == "AddAdmin" ? "active" : "")"
               asp-controller="useraccounts" asp-action="AddAdmin">
                <i class="bi bi-person-plus"></i> Add Admin
            </a>

            <div class="sidebar-section-label">Tools</div>
            <a class="sidebar-link @(ViewContext.RouteData.Values["action"]?.ToString() == "email" ? "active" : "")"
               asp-controller="useraccounts" asp-action="email">
                <i class="bi bi-envelope"></i> Send Email
            </a>
        </nav>

        <div class="sidebar-logout">
            <a asp-controller="useraccounts" asp-action="logout">
                <i class="bi bi-box-arrow-left"></i> Logout
            </a>
        </div>
    </aside>

    <!-- Top bar -->
    <header class="admin-topbar">
        <div style="display:flex;align-items:center;gap:12px;">
            <button class="topbar-hamburger" onclick="toggleSidebar()" aria-label="Toggle menu">
                <i class="bi bi-list"></i>
            </button>
            <span class="topbar-title">@(ViewData["Title"] ?? "Admin")</span>
        </div>
        <div class="topbar-right">
            <span class="topbar-welcome">Welcome, <strong>@Context.Session.GetString("Name")</strong></span>
            <div class="topbar-avatar">
                @{ var n = Context.Session.GetString("Name"); }
                @(n != null && n.Length > 0 ? n[0].ToString().ToUpper() : "A")
            </div>
        </div>
    </header>

    <!-- Main content -->
    <main class="admin-content">
        @RenderBody()
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        function toggleSidebar() {
            document.getElementById('adminSidebar').classList.toggle('open');
            document.getElementById('sidebarOverlay').classList.toggle('open');
        }
        function closeSidebar() {
            document.getElementById('adminSidebar').classList.remove('open');
            document.getElementById('sidebarOverlay').classList.remove('open');
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
