@model IEnumerable<project_web2.Models.Users>

@{
    ViewData["Title"] = "Users";
    var emails = ViewBag.Emails as Dictionary<int, string> ?? new Dictionary<int, string>();
}

<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;">
    <div>
        <div class="admin-page-title">Users</div>
        <div class="admin-page-sub">All registered accounts</div>
    </div>
    <div style="display:flex;gap:10px;">
        <a asp-action="Users_search" class="btn-admin-sm btn-view" style="padding:8px 16px;">
            <i class="bi bi-search"></i> Search
        </a>
        <a asp-action="AddAdmin" class="btn-admin-primary">
            <i class="bi bi-person-plus"></i> Add Admin
        </a>
    </div>
</div>

<div class="admin-card" style="padding:0;overflow:hidden;">
    <table class="admin-table">
        <thead>
            <tr>
                <th style="width:46px;">#</th>
                <th>Username</th>
                <th>Email</th>
                <th>Role</th>
                <th style="text-align:right;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td style="color:#bbb;font-size:.8rem;">@item.Id</td>
                    <td>
                        <div style="display:flex;align-items:center;gap:10px;">
                            <div style="width:34px;height:34px;border-radius:50%;background:@(item.Role=="admin"?"rgba(255,107,0,.15)":"rgba(21,101,192,.12)");display:flex;align-items:center;justify-content:center;font-weight:700;font-size:.85rem;color:@(item.Role=="admin"?"#e05e00":"#1565c0");flex-shrink:0;">
                                @item.Username[0].ToString().ToUpper()
                            </div>
                            <span style="font-weight:600;color:#1a1a2e;">@item.Username</span>
                        </div>
                    </td>
                    <td style="color:#555;font-size:.9rem;">
                        @(emails.ContainsKey(item.Id) ? emails[item.Id] : "N/A")
                    </td>
                    <td>
                        @if (item.Role == "admin")
                        {
                            <span class="role-badge role-admin"><i class="bi bi-shield-check me-1"></i>Admin</span>
                        }
                        else
                        {
                            <span class="role-badge role-customer"><i class="bi bi-person me-1"></i>Customer</span>
                        }
                    </td>
                    <td style="text-align:right;white-space:nowrap;">
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn-admin-sm btn-view">
                            <i class="bi bi-eye"></i> View
                        </a>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn-admin-sm btn-edit">
                            <i class="bi bi-pencil"></i> Edit
                        </a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn-admin-sm btn-delete">
                            <i class="bi bi-trash"></i> Delete
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (!Model.Any())
    {
        <div style="text-align:center;padding:48px 24px;color:#aaa;">
            <i class="bi bi-people" style="font-size:2.5rem;display:block;margin-bottom:12px;"></i>
            No users found.
        </div>
    }
</div>
