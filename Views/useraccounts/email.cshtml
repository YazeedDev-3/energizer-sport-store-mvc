@{
    ViewData["Title"] = "Send Email";
}

<div style="max-width:560px;">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;">
        <div>
            <div class="admin-page-title">Send Email</div>
            <div class="admin-page-sub">Send a message directly to a customer</div>
        </div>
    </div>

    @if (ViewData["Message"] != null)
    {
        <div style="background:rgba(27,153,80,.1);color:#1b9950;border-radius:8px;padding:12px 16px;display:flex;align-items:center;gap:10px;margin-bottom:20px;font-size:.875rem;font-weight:500;">
            <i class="bi bi-check-circle-fill"></i>
            @ViewData["Message"]
        </div>
    }

    <div class="admin-card">
        <form asp-action="email" method="post">
            <div class="admin-form-group">
                <label for="address">
                    <i class="bi bi-envelope me-1" style="color:#ff6b00;"></i> To (Email Address)
                </label>
                <input name="address" id="address" class="form-control" type="email"
                       required placeholder="customer@example.com" />
            </div>

            <div class="admin-form-group">
                <label for="subject">
                    <i class="bi bi-tag me-1" style="color:#ff6b00;"></i> Subject
                </label>
                <input name="subject" id="subject" class="form-control" type="text"
                       required placeholder="Email subject" />
            </div>

            <div class="admin-form-group">
                <label for="body">
                    <i class="bi bi-chat-text me-1" style="color:#ff6b00;"></i> Message
                </label>
                <textarea name="body" id="body" class="form-control" rows="6"
                          required placeholder="Write your message here..."></textarea>
            </div>

            <div style="margin-top:8px;">
                <button type="submit" class="btn-admin-primary">
                    <i class="bi bi-send"></i> Send Email
                </button>
            </div>
        </form>
    </div>
</div>
