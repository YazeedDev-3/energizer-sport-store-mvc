@model project_web2.Models.Users

@{
    ViewData["Title"] = "Search Users";
}

<div style="max-width:560px;">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;">
        <div>
            <div class="admin-page-title">Search Users</div>
            <div class="admin-page-sub">Filter by role then select a user</div>
        </div>
        <a asp-action="Index" class="btn-admin-sm btn-view">
            <i class="bi bi-arrow-left"></i> All Users
        </a>
    </div>

    <div class="admin-card">
        <form asp-action="Users_search">
            <div class="admin-form-group">
                <label>Filter by Role</label>
                <select class="form-control" name="cat" id="ca" onchange="gettitle()">
                    <option value="0">— Select role —</option>
                    <option value="admin">Admin</option>
                    <option value="customer">Customer</option>
                </select>
            </div>
            <div class="admin-form-group">
                <label>Select User</label>
                <select class="form-control" name="name" id="ti">
                    <option>— Select role first —</option>
                </select>
            </div>
            <button type="submit" class="btn-admin-primary">
                <i class="bi bi-search"></i> Show User
            </button>
        </form>
    </div>

    @if (Model?.Username != null)
    {
        <div class="admin-card" style="border-top:3px solid #ff6b00;">
            <div style="display:flex;align-items:center;gap:14px;margin-bottom:16px;">
                <div style="width:48px;height:48px;border-radius:50%;background:@(Model.Role=="admin"?"rgba(255,107,0,.15)":"rgba(21,101,192,.12)");display:flex;align-items:center;justify-content:center;font-weight:800;font-size:1.1rem;color:@(Model.Role=="admin"?"#e05e00":"#1565c0");flex-shrink:0;">
                    @Model.Username[0].ToString().ToUpper()
                </div>
                <div>
                    <div style="font-size:1rem;font-weight:700;color:#1a1a2e;">@Model.Username</div>
                    @if (Model.Role == "admin")
                    {
                        <span class="role-badge role-admin"><i class="bi bi-shield-check me-1"></i>Admin</span>
                    }
                    else
                    {
                        <span class="role-badge role-customer"><i class="bi bi-person me-1"></i>Customer</span>
                    }
                </div>
            </div>
            <div style="display:flex;gap:10px;">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-admin-sm btn-edit" style="padding:8px 16px;">
                    <i class="bi bi-pencil"></i> Edit
                </a>
                <a asp-action="Delete" asp-route-id="@Model.Id" class="btn-admin-sm btn-delete" style="padding:8px 16px;">
                    <i class="bi bi-trash"></i> Delete
                </a>
            </div>
        </div>
    }
</div>

<script>
    async function gettitle() {
        var cc = document.getElementById('ca').value;
        var response = await fetch('/getname/' + cc);
        let x = await response.json();
        var dd = "<option>— Select user —</option>";
        for (var i = 0; i < x.length; i++) {
            dd += "<option>" + x[i].name + "</option>";
        }
        document.getElementById("ti").innerHTML = dd;
    }
</script>
