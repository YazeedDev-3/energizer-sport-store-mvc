@{
    ViewData["Title"] = "Login";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login — Energizer Sport</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="login-page">

    <div class="auth-card">

        <div class="auth-logo-wrap">
            <img src="~/images/Energizer_Sport_Logo.png" alt="Energizer Sport" class="auth-logo" />
            <span class="auth-store-name">Energizer Sport</span>
        </div>

        <h2 class="auth-title">Welcome Back</h2>
        <hr class="auth-divider" />

        <form asp-action="Login" method="post">
            <input type="hidden" name="returnUrl" value="@Context.Request.Query["returnUrl"]" />

            <div class="auth-field">
                <label for="username">Username</label>
                <div class="auth-input-wrap">
                    <i class="bi bi-person-fill auth-icon"></i>
                    <input id="username" name="na" class="auth-input" placeholder="Enter your username" autocomplete="username" />
                </div>
            </div>

            <div class="auth-field">
                <label for="password">Password</label>
                <div class="auth-input-wrap">
                    <i class="bi bi-lock-fill auth-icon"></i>
                    <input type="password" id="password" name="pa" class="auth-input" placeholder="Enter your password" autocomplete="current-password" />
                </div>
            </div>

            <div class="auth-checkbox-row">
                <input type="checkbox" name="auto" id="auto-login" value="on" />
                <label for="auto-login">Keep me logged in</label>
            </div>

            <button type="submit" class="btn-auth">
                <i class="bi bi-box-arrow-in-right me-2"></i>Login
            </button>

            <p class="auth-error">@ViewData["Message"]</p>
        </form>

        <p class="auth-footer-note">
            Don't have an account? <a asp-action="registration" asp-controller="useraccounts">Create one</a>
        </p>
    </div>

</body>
</html>
