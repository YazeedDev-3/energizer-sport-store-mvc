@model IEnumerable<project_web2.Models.Products>

@{
    ViewData["Title"] = "Product List";

    string CategoryName(int id) => id switch {
        1 => "Protein Powder",
        2 => "Pre-Workout",
        3 => "Creatine",
        4 => "Snack",
        5 => "Vitamins",
        _ => "Other"
    };

    string CategoryStyle(int id) => id switch {
        1 => "background:rgba(255,107,0,.1);color:#e05e00;",
        2 => "background:rgba(21,101,192,.1);color:#1565c0;",
        3 => "background:rgba(27,153,80,.1);color:#1b9950;",
        4 => "background:rgba(103,58,183,.1);color:#673ab7;",
        5 => "background:rgba(0,150,136,.1);color:#00796b;",
        _ => "background:#f0f0f0;color:#555;"
    };
}

<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;">
    <div>
        <div class="admin-page-title">Product List</div>
        <div class="admin-page-sub">All products in the catalogue</div>
    </div>
    <a asp-action="Create" class="btn-admin-primary">
        <i class="bi bi-plus-circle"></i> Add Product
    </a>
</div>

<div class="admin-card" style="padding:0;overflow:hidden;">
    <table class="admin-table">
        <thead>
            <tr>
                <th style="width:46px;">#</th>
                <th>Name</th>
                <th>Description</th>
                <th>Price</th>
                <th>Category</th>
                <th>Stock</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td style="color:#bbb;font-size:.8rem;">@item.Id</td>
                    <td style="font-weight:600;color:#1a1a2e;">@item.Name</td>
                    <td style="color:#777;max-width:220px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">@item.Description</td>
                    <td style="font-weight:600;">@item.Price.ToString("F2") SR</td>
                    <td>
                        <span class="role-badge" style="@CategoryStyle(item.CategoryId)">
                            @CategoryName(item.CategoryId)
                        </span>
                    </td>
                    <td>
                        @if (item.Stock > 0)
                        {
                            <span style="color:#1b9950;font-weight:600;">@item.Stock</span>
                        }
                        else
                        {
                            <span style="color:#c62828;font-weight:600;">0</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (!Model.Any())
    {
        <div style="text-align:center;padding:40px;color:#aaa;">
            <i class="bi bi-box-seam" style="font-size:2rem;display:block;margin-bottom:10px;"></i>
            No products found.
        </div>
    }
</div>
