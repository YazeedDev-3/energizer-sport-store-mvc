@model project_web2.Models.Products

@{
    ViewData["Title"] = "Delete Product";
}

<div style="max-width:520px;">
    <div class="admin-page-title" style="margin-bottom:4px;">Delete Product</div>
    <div class="admin-page-sub">This action cannot be undone.</div>

    <div class="admin-card" style="border-top:4px solid #c62828;">
        <div style="display:flex;align-items:flex-start;gap:16px;margin-bottom:20px;">
            @if (!string.IsNullOrEmpty(Model.ImageFile))
            {
                <img src="~/images/@Model.ImageFile" alt="@Model.Name"
                     style="width:72px;height:72px;object-fit:cover;border-radius:8px;border:1px solid #eee;flex-shrink:0;" />
            }
            else
            {
                <div style="width:72px;height:72px;border-radius:8px;background:#f4f6fb;display:flex;align-items:center;justify-content:center;color:#bbb;flex-shrink:0;">
                    <i class="bi bi-image" style="font-size:1.8rem;"></i>
                </div>
            }
            <div>
                <div style="font-size:1.1rem;font-weight:700;color:#1a1a2e;">@Model.Name</div>
                <div style="font-size:.85rem;color:#888;margin-top:4px;">@Model.Description</div>
            </div>
        </div>

        <div style="background:#f8f9fc;border-radius:8px;padding:14px 18px;margin-bottom:20px;">
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;font-size:.85rem;">
                <div><span style="color:#888;">Price:</span> <strong>@Model.Price.ToString("F2") SR</strong></div>
                <div><span style="color:#888;">Stock:</span> <strong>@Model.Stock units</strong></div>
                <div><span style="color:#888;">Discount:</span> <strong>@Model.Discount%</strong></div>
                <div><span style="color:#888;">Category ID:</span> <strong>@Model.CategoryId</strong></div>
            </div>
        </div>

        <div style="background:#fdecea;border-radius:8px;padding:12px 16px;display:flex;align-items:center;gap:10px;margin-bottom:24px;font-size:.85rem;color:#c62828;">
            <i class="bi bi-exclamation-triangle-fill"></i>
            Are you sure you want to permanently delete <strong>@Model.Name</strong>?
        </div>

        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />
            <div style="display:flex;gap:12px;">
                <button type="submit" class="btn-admin-primary" style="background:#c62828;">
                    <i class="bi bi-trash"></i> Yes, Delete
                </button>
                <a asp-action="Index" class="btn-admin-sm btn-view" style="padding:9px 18px;">
                    Cancel
                </a>
            </div>
        </form>
    </div>
</div>
