@model project_web2.Models.Products

@{
    ViewData["Title"] = "Product Details";
    var isCustomer = (string)ViewData["role"] == "customer";
    var isAdmin    = (string)ViewData["role"] == "admin";
}

@if (isCustomer)
{
    Layout = "~/Views/Shared/layoutCustomer.cshtml";
    <h1>@Model.Name</h1>
    <img src="~/images/@Model.ImageFile" height="150" />
    <p>@Model.Description</p>
    <p>Price: @Model.Price SR</p>
    <p>Discount: @Model.Discount%</p>
    <a asp-action="Index" class="btn btn-secondary">Back</a>
    return;
}

@* Admin view *@
<div style="max-width:560px;">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;">
        <div>
            <div class="admin-page-title">Product Details</div>
            <div class="admin-page-sub">ID #@Model.Id</div>
        </div>
        <a asp-action="Index" class="btn-admin-sm btn-view">
            <i class="bi bi-arrow-left"></i> Back to List
        </a>
    </div>

    <div class="admin-card">
        @if (!string.IsNullOrEmpty(Model.ImageFile))
        {
            <img src="~/images/@Model.ImageFile" alt="@Model.Name"
                 style="width:100%;max-height:220px;object-fit:contain;border-radius:8px;border:1px solid #eee;margin-bottom:20px;" />
        }

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:0;">
            <div style="padding:12px 0;border-bottom:1px solid #f0f2f5;">
                <div style="font-size:.75rem;color:#999;font-weight:600;text-transform:uppercase;letter-spacing:.05em;">Name</div>
                <div style="font-weight:700;color:#1a1a2e;margin-top:2px;">@Model.Name</div>
            </div>
            <div style="padding:12px 0;border-bottom:1px solid #f0f2f5;">
                <div style="font-size:.75rem;color:#999;font-weight:600;text-transform:uppercase;letter-spacing:.05em;">Price</div>
                <div style="font-weight:700;color:#1a1a2e;margin-top:2px;">@Model.Price.ToString("F2") SR</div>
            </div>
            <div style="padding:12px 0;border-bottom:1px solid #f0f2f5;">
                <div style="font-size:.75rem;color:#999;font-weight:600;text-transform:uppercase;letter-spacing:.05em;">Discount</div>
                <div style="font-weight:700;color:#e05e00;margin-top:2px;">@Model.Discount%</div>
            </div>
            <div style="padding:12px 0;border-bottom:1px solid #f0f2f5;">
                <div style="font-size:.75rem;color:#999;font-weight:600;text-transform:uppercase;letter-spacing:.05em;">Stock</div>
                <div style="font-weight:700;color:@(Model.Stock > 0 ? "#1b9950" : "#c62828");margin-top:2px;">
                    @(Model.Stock > 0 ? $"{Model.Stock} units" : "Out of Stock")
                </div>
            </div>
            <div style="padding:12px 0;border-bottom:1px solid #f0f2f5;">
                <div style="font-size:.75rem;color:#999;font-weight:600;text-transform:uppercase;letter-spacing:.05em;">Category ID</div>
                <div style="font-weight:700;color:#1a1a2e;margin-top:2px;">@Model.CategoryId</div>
            </div>
            @if (isAdmin)
            {
                <div style="padding:12px 0;border-bottom:1px solid #f0f2f5;">
                    <div style="font-size:.75rem;color:#999;font-weight:600;text-transform:uppercase;letter-spacing:.05em;">Created At</div>
                    <div style="font-weight:700;color:#1a1a2e;margin-top:2px;">@Model.CreatedAt.ToString("yyyy-MM-dd")</div>
                </div>
            }
        </div>

        @if (!string.IsNullOrEmpty(Model.Description))
        {
            <div style="margin-top:16px;">
                <div style="font-size:.75rem;color:#999;font-weight:600;text-transform:uppercase;letter-spacing:.05em;">Description</div>
                <div style="margin-top:4px;color:#333;line-height:1.55;">@Model.Description</div>
            </div>
        }

        <div style="display:flex;gap:12px;margin-top:24px;">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-admin-sm btn-edit" style="padding:8px 18px;">
                <i class="bi bi-pencil"></i> Edit
            </a>
            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn-admin-sm btn-delete" style="padding:8px 18px;">
                <i class="bi bi-trash"></i> Delete
            </a>
        </div>
    </div>
</div>
