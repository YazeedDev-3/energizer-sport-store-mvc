@model IEnumerable<project_web2.Models.Products>

@{
    var role = ViewData["role"] as string;
}

@* ── Customer view: use customer layout (unchanged) ── *@
@if (role == "customer")
{
    Layout = "~/Views/Shared/layoutCustomer.cshtml";
    ViewData["Title"] = "Products";
    <h1>Products</h1>
    <table class="table">
        <thead><tr><th>Name</th><th>Price</th><th>Image</th><th></th></tr></thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Name</td>
                    <td>@item.Price SR</td>
                    <td><img src="~/images/@item.ImageFile" width="80" height="80" /></td>
                    <td><a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm">Details</a></td>
                </tr>
            }
        </tbody>
    </table>
    return;
}

@* ── Admin view ── *@
@{
    ViewData["Title"] = "Products";

    string CategoryName(int id) => id switch {
        1 => "Protein Powder",
        2 => "Pre-Workout",
        3 => "Creatine",
        4 => "Snack",
        5 => "Vitamins",
        _ => "Other"
    };

    string CategoryColor(int id) => id switch {
        1 => "background:rgba(255,107,0,.1);color:#e05e00;",
        2 => "background:rgba(21,101,192,.1);color:#1565c0;",
        3 => "background:rgba(27,153,80,.1);color:#1b9950;",
        4 => "background:rgba(103,58,183,.1);color:#673ab7;",
        5 => "background:rgba(0,150,136,.1);color:#00796b;",
        _ => "background:#f0f0f0;color:#555;"
    };
}

<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;">
    <div>
        <div class="admin-page-title">Products</div>
        <div class="admin-page-sub">Manage your product catalogue</div>
    </div>
    <a asp-action="Create" class="btn-admin-primary">
        <i class="bi bi-plus-circle"></i> Add Product
    </a>
</div>

<div class="admin-card" style="padding:0;overflow:hidden;">
    <table class="admin-table">
        <thead>
            <tr>
                <th style="width:70px;">Image</th>
                <th>Name</th>
                <th>Category</th>
                <th>Price</th>
                <th>Stock</th>
                <th>Discount</th>
                <th style="text-align:right;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        @if (!string.IsNullOrEmpty(item.ImageFile))
                        {
                            <img src="~/images/@item.ImageFile" alt="@item.Name"
                                 style="width:52px;height:52px;object-fit:cover;border-radius:8px;border:1px solid #eee;" />
                        }
                        else
                        {
                            <div style="width:52px;height:52px;border-radius:8px;background:#f4f6fb;display:flex;align-items:center;justify-content:center;color:#bbb;">
                                <i class="bi bi-image" style="font-size:1.3rem;"></i>
                            </div>
                        }
                    </td>
                    <td>
                        <div style="font-weight:600;color:#1a1a2e;">@item.Name</div>
                        <div style="font-size:.75rem;color:#999;margin-top:2px;">ID #@item.Id</div>
                    </td>
                    <td>
                        <span class="role-badge" style="@CategoryColor(item.CategoryId)">
                            @CategoryName(item.CategoryId)
                        </span>
                    </td>
                    <td style="font-weight:600;">@item.Price.ToString("F2") SR</td>
                    <td>
                        @if (item.Stock > 0)
                        {
                            <span style="color:#1b9950;font-weight:600;">@item.Stock</span>
                        }
                        else
                        {
                            <span style="color:#c62828;font-weight:600;">Out of Stock</span>
                        }
                    </td>
                    <td>
                        @if (item.Discount > 0)
                        {
                            <span class="role-badge" style="background:rgba(255,107,0,.1);color:#e05e00;">@item.Discount%</span>
                        }
                        else
                        {
                            <span style="color:#bbb;font-size:.8rem;">—</span>
                        }
                    </td>
                    <td style="text-align:right;white-space:nowrap;">
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn-admin-sm btn-view">
                            <i class="bi bi-eye"></i> View
                        </a>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn-admin-sm btn-edit">
                            <i class="bi bi-pencil"></i> Edit
                        </a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn-admin-sm btn-delete">
                            <i class="bi bi-trash"></i> Delete
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (!Model.Any())
    {
        <div style="text-align:center;padding:48px 24px;color:#aaa;">
            <i class="bi bi-box-seam" style="font-size:2.5rem;display:block;margin-bottom:12px;"></i>
            No products yet. <a asp-action="Create" style="color:#ff6b00;">Add your first product.</a>
        </div>
    }
</div>
