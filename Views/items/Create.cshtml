@model project_web2.Models.Products

@{
    ViewData["Title"] = "Add Product";
}

<div style="max-width:640px;">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;">
        <div>
            <div class="admin-page-title">Add Product</div>
            <div class="admin-page-sub">Fill in the details for the new product</div>
        </div>
        <a asp-action="Index" class="btn-admin-sm btn-view">
            <i class="bi bi-arrow-left"></i> Back to List
        </a>
    </div>

    <div class="admin-card">
        <form asp-action="Create" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" style="color:#c62828;background:#fdecea;padding:10px 14px;border-radius:8px;margin-bottom:16px;font-size:.85rem;"></div>

            <div class="admin-form-group">
                <label asp-for="Name">Product Name</label>
                <input asp-for="Name" class="form-control" placeholder="e.g. Whey Protein 1kg" />
                <span asp-validation-for="Name" style="color:#c62828;font-size:.78rem;"></span>
            </div>

            <div class="admin-form-group">
                <label asp-for="Description">Description</label>
                <textarea asp-for="Description" class="form-control" rows="3" placeholder="Short product description"></textarea>
                <span asp-validation-for="Description" style="color:#c62828;font-size:.78rem;"></span>
            </div>

            <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
                <div class="admin-form-group">
                    <label asp-for="Price">Price (SR)</label>
                    <input asp-for="Price" class="form-control" type="number" step="0.01" min="0" placeholder="0.00" />
                    <span asp-validation-for="Price" style="color:#c62828;font-size:.78rem;"></span>
                </div>
                <div class="admin-form-group">
                    <label asp-for="Discount">Discount (%)</label>
                    <input asp-for="Discount" class="form-control" type="number" step="0.01" min="0" max="100" placeholder="0" />
                    <span asp-validation-for="Discount" style="color:#c62828;font-size:.78rem;"></span>
                </div>
            </div>

            <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
                <div class="admin-form-group">
                    <label asp-for="Stock">Stock Quantity</label>
                    <input asp-for="Stock" class="form-control" type="number" min="0" placeholder="0" />
                    <span asp-validation-for="Stock" style="color:#c62828;font-size:.78rem;"></span>
                </div>
                <div class="admin-form-group">
                    <label asp-for="CategoryId">Category</label>
                    <select asp-for="CategoryId" class="form-control">
                        <option value="">— Select category —</option>
                        <option value="1">Protein Powder</option>
                        <option value="2">Pre-Workout</option>
                        <option value="3">Creatine</option>
                        <option value="4">Snack</option>
                        <option value="5">Vitamins</option>
                    </select>
                    <span asp-validation-for="CategoryId" style="color:#c62828;font-size:.78rem;"></span>
                </div>
            </div>

            <div class="admin-form-group">
                <label>Product Image</label>
                <input type="file" name="file" class="form-control" accept="image/*" />
                <div style="font-size:.75rem;color:#999;margin-top:4px;">Optional. Accepted: JPG, PNG, WebP.</div>
            </div>

            <div style="display:flex;gap:12px;margin-top:8px;">
                <button type="submit" class="btn-admin-primary">
                    <i class="bi bi-plus-circle"></i> Add Product
                </button>
                <a asp-action="Index" class="btn-admin-sm btn-view" style="padding:9px 18px;">
                    Cancel
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
